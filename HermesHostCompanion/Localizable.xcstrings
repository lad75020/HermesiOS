    "The companion uses a single 256-character API key over plain HTTP WebSocket. Copy this key into HermesiOS settings. No TLS, certificates, QR codes, enrollment ports, pairing IDs, or CA material are used.": {
      "extractionState": "extracted",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The companion uses a single 256-character API key over plain HTTP WebSocket. Copy this key into HermesiOS settings. No TLS, certificates, QR codes, enrollment ports, pairing IDs, or CA material are used."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le compagnon utilise une unique clé API de 256 caractères via WebSocket HTTP non chiffré. Copiez cette clé dans les réglages d’HermesiOS. Aucun TLS, certificat, code QR, port d’inscription, identifiant de jumelage ni matériel d’AC n’est utilisé."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El companion usa una única clave de API de 256 caracteres sobre WebSocket HTTP sin cifrar. Copia esta clave en los ajustes de HermesiOS. No se usan TLS, certificados, códigos QR, puertos de inscripción, IDs de emparejamiento ni material de CA."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Companion verwendet einen einzelnen 256-stelligen API-Schlüssel über einfachen HTTP-WebSocket. Kopiere diesen Schlüssel in die HermesiOS-Einstellungen. TLS, Zertifikate, QR-Codes, Registrierungsports, Kopplungs-IDs oder CA-Material werden nicht verwendet."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "伴侣通过明文 HTTP WebSocket 使用单个 256 字符 API 密钥。请将此密钥复制到 HermesiOS 设置中。不使用 TLS、证书、二维码、注册端口、配对 ID 或 CA 材料。"
          }
        }
      }
    },
    "The listener binds to local loopback; this advertised value controls the endpoint shown to iOS clients and may be served through Tailscale.": {
      "extractionState": "extracted",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The listener binds to local loopback; this advertised value controls the endpoint shown to iOS clients and may be served through Tailscale."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le service d’écoute se lie à la boucle locale ; cette valeur annoncée contrôle le point de terminaison affiché aux clients iOS et peut être servi via Tailscale."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El listener se enlaza al loopback local; este valor anunciado controla el endpoint mostrado a los clientes iOS y puede servirse mediante Tailscale."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Listener bindet sich an den lokalen Loopback; dieser angezeigte Wert steuert den Endpunkt, der iOS-Clients angezeigt wird, und kann über Tailscale bereitgestellt werden."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "监听器绑定到本地回环地址；此公布值控制显示给 iOS 客户端的端点，并可通过 Tailscale 提供服务。"
          }
        }
      }
    },
    "Use your Tailscale hostname or stable IP here so the API endpoint targets the right machine from elsewhere on the same Tailnet.": {
      "extractionState": "extracted",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use your Tailscale hostname or stable IP here so the API endpoint targets the right machine from elsewhere on the same Tailnet."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez ici votre nom d’hôte Tailscale ou une IP stable afin que le point de terminaison de l’API cible la bonne machine depuis le même Tailnet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa aquí tu nombre de host de Tailscale o una IP estable para que el endpoint de API apunte a la máquina correcta desde otro lugar de la misma Tailnet."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwende hier deinen Tailscale-Hostnamen oder eine stabile IP, damit der API-Endpunkt von anderer Stelle im selben Tailnet auf den richtigen Rechner zeigt."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在此使用你的 Tailscale 主机名或固定 IP，以便同一 Tailnet 中其他位置的 API 端点指向正确的机器。"
          }
        }
      }
    }
  },
  "version": "1.0"
}
