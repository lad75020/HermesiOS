    "Minimal V1 companion daemon shell for plain HTTP WebSocket access protected by one 256-character API key.": {
      "extractionState": "extracted",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Minimal V1 companion daemon shell for plain HTTP WebSocket access protected by one 256-character API key."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Interface minimale du démon compagnon V1 pour un accès WebSocket HTTP non chiffré protégé par une clé API de 256 caractères."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Shell mínima del daemon companion V1 para acceso WebSocket HTTP sin cifrar, protegido por una clave de API de 256 caracteres."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Minimale V1-Companion-Daemon-Shell für einfachen HTTP-WebSocket-Zugriff, geschützt durch einen 256-stelligen API-Schlüssel."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "最小化的 V1 伴侣守护进程外壳，用于通过一个 256 字符 API 密钥保护的明文 HTTP WebSocket 访问。"
          }
        }
      }
    },
