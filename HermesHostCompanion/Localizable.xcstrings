    "Apply the network target before copying the endpoint to iOS.": {
      "extractionState": "extracted",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Apply the network target before copying the endpoint to iOS."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appliquez la cible réseau avant de copier le point de terminaison vers iOS."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplica el destino de red antes de copiar el endpoint a iOS."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Übernimm das Netzwerkziel, bevor du den Endpunkt nach iOS kopierst."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "先应用网络目标，再将端点复制到 iOS。"
          }
        }
      }
    },
    "Applying host or port changes will restart the running companion server automatically.": {
      "extractionState": "extracted",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Applying host or port changes will restart the running companion server automatically."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’application des modifications d’hôte ou de port redémarrera automatiquement le serveur compagnon en cours d’exécution."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Al aplicar cambios de host o puerto, el servidor companion en ejecución se reiniciará automáticamente."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Änderungen an Host oder Port starten den laufenden Companion-Server automatisch neu."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "应用主机或端口更改会自动重启正在运行的伴侣服务器。"
          }
        }
      }
    },
