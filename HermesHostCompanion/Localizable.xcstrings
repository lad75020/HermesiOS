    "Regenerating invalidates every iOS device until the new API key is copied into settings.": {
      "extractionState": "extracted",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Regenerating invalidates every iOS device until the new API key is copied into settings."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La régénération invalide tous les appareils iOS jusqu’à ce que la nouvelle clé API soit copiée dans les réglages."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Regenerarla invalida todos los dispositivos iOS hasta que la nueva clave de API se copie en Ajustes."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Durch das Neuerzeugen werden alle iOS-Geräte ungültig, bis der neue API-Schlüssel in die Einstellungen kopiert wurde."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "重新生成后，所有 iOS 设备都会失效，直到将新的 API 密钥复制到设置中。"
          }
        }
      }
    },
