    "Used with the service TCP ports below to build the HTTPS and WSS URLs, and as the SSH host for the Terminal tab.": {
      "extractionState": "extracted",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Used with the service TCP ports below to build the HTTPS and WSS URLs, and as the SSH host for the Terminal tab."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisé avec les ports TCP de service ci-dessous pour construire les URL HTTPS et WSS, ainsi que comme hôte SSH pour l’onglet Terminal."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se usa con los puertos TCP de servicio de abajo para construir las URL HTTPS y WSS, y como host SSH para la pestaña Terminal."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wird mit den untenstehenden Dienst-TCP-Ports verwendet, um die HTTPS- und WSS-URLs zu erstellen, sowie als SSH-Host für den Terminal-Tab."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "与下方服务 TCP 端口一起用于构建 HTTPS 和 WSS URL，并作为“终端”标签页的 SSH 主机。"
          }
        }
      }
    },
