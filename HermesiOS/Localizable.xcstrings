    "Edits the same provider and tool API keys as desktop Providers, writing to `.env` on the macOS host via the API-key-authenticated WebSocket companion.": {
      "extractionState": "extracted",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Edits the same provider and tool API keys as desktop Providers, writing to `.env` on the macOS host via the API-key-authenticated WebSocket companion."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Modifie les mêmes clés API de fournisseurs et d’outils que Providers sur desktop, en écrivant dans `.env` sur l’hôte macOS via le compagnon WebSocket authentifié par clé API."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Edita las mismas claves de API de proveedor y herramientas que Providers de escritorio, escribiendo en `.env` en el host macOS mediante el companion WebSocket autenticado con clave de API."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bearbeitet dieselben Anbieter- und Tool-API-Schlüssel wie Desktop Providers und schreibt über den API-schlüssel-authentifizierten WebSocket-Companion in `.env` auf dem macOS-Host."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "编辑与桌面端 Providers 相同的提供商和工具 API 密钥，并通过 API 密钥认证的 WebSocket 伴侣写入 macOS 主机上的 `.env`。"
          }
        }
      }
    },
