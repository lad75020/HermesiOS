    "Configure the provider and model that Hermes Agent uses for the main conversation, delegated sub-agents, and auxiliary runtime tasks. Changes are written to the live `config.yaml` on the macOS host.": {
      "extractionState": "extracted",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Configure the provider and model that Hermes Agent uses for the main conversation, delegated sub-agents, and auxiliary runtime tasks. Changes are written to the live `config.yaml` on the macOS host."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Configurez le fournisseur et le modèle que Hermes Agent utilise pour la conversation principale, les sous-agents délégués et les tâches d’exécution auxiliaires. Les modifications sont écrites dans le `config.yaml` actif sur l’hôte macOS."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Configura el proveedor y el modelo que Hermes Agent usa para la conversación principal, los subagentes delegados y las tareas auxiliares en tiempo de ejecución. Los cambios se escriben en el `config.yaml` activo del host macOS."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Konfiguriere Anbieter und Modell, die Hermes Agent für die Hauptunterhaltung, delegierte Sub-Agenten und zusätzliche Laufzeitaufgaben verwendet. Änderungen werden in die aktive `config.yaml` auf dem macOS-Host geschrieben."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "配置 Hermes Agent 用于主对话、委派子代理和辅助运行时任务的提供商与模型。更改会写入 macOS 主机上的实时 `config.yaml`。"
          }
        }
      }
    },
