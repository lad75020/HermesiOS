    "Loaded from the configured keys currently present in `.env`. Edit values inline, add a new provider key, or remove a key from the host `.env` file.": {
      "extractionState": "extracted",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Loaded from the configured keys currently present in `.env`. Edit values inline, add a new provider key, or remove a key from the host `.env` file."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chargé depuis les clés configurées actuellement présentes dans `.env`. Modifiez les valeurs en ligne, ajoutez une nouvelle clé de fournisseur ou supprimez une clé du fichier `.env` de l’hôte."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cargado desde las claves configuradas presentes actualmente en `.env`. Edita valores en línea, añade una nueva clave de proveedor o elimina una clave del archivo `.env` del host."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Geladen aus den konfigurierten Schlüsseln, die derzeit in `.env` vorhanden sind. Bearbeite Werte direkt, füge einen neuen Anbieter-Schlüssel hinzu oder entferne einen Schlüssel aus der `.env`-Datei des Hosts."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从 `.env` 中当前存在的已配置密钥加载。可内联编辑值、添加新的提供商密钥，或从主机 `.env` 文件中移除密钥。"
          }
        }
      }
    },
