    "Toggle any skill on to mark it active in Hermes, or off to archive it from the live workspace state.": {
      "extractionState": "extracted",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Toggle any skill on to mark it active in Hermes, or off to archive it from the live workspace state."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activez une skill pour la marquer comme active dans Hermes, ou désactivez-la pour l’archiver depuis l’état actif de l’espace de travail."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Activa cualquier habilidad para marcarla como activa en Hermes, o desactívala para archivarla desde el estado activo del espacio de trabajo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
