    "Search the Mac dashboard history to query conversations across all Hermes channels.": {
      "extractionState": "extracted",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Search the Mac dashboard history to query conversations across all Hermes channels."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Recherchez dans l’historique du tableau de bord Mac pour interroger les conversations sur tous les canaux Hermes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Busca en el historial del panel del Mac para consultar conversaciones en todos los canales de Hermes."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Durchsuche den Mac-Dashboard-Verlauf, um Unterhaltungen über alle Hermes-Kanäle hinweg abzufragen."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "搜索 Mac 仪表板历史，以查询所有 Hermes 渠道中的对话。"
          }
        }
      }
    },
    "Searches the Mac dashboard server through the protected /api/sessions/search/conversations endpoint. Natural words and SQLite FTS-style queries are accepted; matching sessions are returned as full conversations.": {
      "extractionState": "extracted",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Searches the Mac dashboard server through the protected /api/sessions/search/conversations endpoint. Natural words and SQLite FTS-style queries are accepted; matching sessions are returned as full conversations."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Recherche sur le serveur du tableau de bord Mac via le point de terminaison protégé /api/sessions/search/conversations. Les mots naturels et les requêtes de style SQLite FTS sont acceptés ; les sessions correspondantes sont renvoyées sous forme de conversations complètes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Busca en el servidor del panel del Mac mediante el endpoint protegido /api/sessions/search/conversations. Se aceptan palabras naturales y consultas de estilo SQLite FTS; las sesiones coincidentes se devuelven como conversaciones completas."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Durchsucht den Mac-Dashboard-Server über den geschützten Endpunkt /api/sessions/search/conversations. Natürliche Wörter und Abfragen im SQLite-FTS-Stil werden akzeptiert; passende Sitzungen werden als vollständige Unterhaltungen zurückgegeben."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通过受保护的 /api/sessions/search/conversations 端点搜索 Mac 仪表板服务器。支持自然语言词语和 SQLite FTS 风格查询；匹配的会话会以完整对话返回。"
          }
        }
      }
    },
