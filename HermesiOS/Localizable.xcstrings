    "Runs tailscale serve --bg --https=<TCP_PORT> http://localhost:<TCP_PORT> when enabled, and tailscale serve --https=<TCP_PORT> off when disabled. The Host Companion port is intentionally excluded.": {
      "extractionState": "extracted",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Runs tailscale serve --bg --https=<TCP_PORT> http://localhost:<TCP_PORT> when enabled, and tailscale serve --https=<TCP_PORT> off when disabled. The Host Companion port is intentionally excluded."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Exécute tailscale serve --bg --https=<TCP_PORT> http://localhost:<TCP_PORT> lorsqu’activé, et tailscale serve --https=<TCP_PORT> off lorsqu’il est désactivé. Le port du compagnon hôte est volontairement exclu."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ejecuta tailscale serve --bg --https=<TCP_PORT> http://localhost:<TCP_PORT> cuando está activado, y tailscale serve --https=<TCP_PORT> off cuando está desactivado. El puerto de Host Companion se excluye intencionalmente."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Führt bei Aktivierung tailscale serve --bg --https=<TCP_PORT> http://localhost:<TCP_PORT> aus und bei Deaktivierung tailscale serve --https=<TCP_PORT> off. Der Host-Companion-Port ist absichtlich ausgeschlossen."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "启用时运行 tailscale serve --bg --https=<TCP_PORT> http://localhost:<TCP_PORT>；禁用时运行 tailscale serve --https=<TCP_PORT> off。Host Companion 端口会被有意排除。"
          }
        }
      }
    },
