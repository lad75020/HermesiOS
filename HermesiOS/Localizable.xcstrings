    },
    "Mirrors the desktop Memory screen: reads and writes `memories/MEMORY.md`, `memories/USER.md`, memory provider config, and memory provider env keys through HermesHostCompanion.": {
      "extractionState": "extracted",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Mirrors the desktop Memory screen: reads and writes `memories/MEMORY.md`, `memories/USER.md`, memory provider config, and memory provider env keys through HermesHostCompanion."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Reflète l’écran Memory sur desktop : lit et écrit `memories/MEMORY.md`, `memories/USER.md`, la configuration du fournisseur de mémoire et les clés d’environnement du fournisseur de mémoire via HermesHostCompanion."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Refleja la pantalla Memory de escritorio: lee y escribe `memories/MEMORY.md`, `memories/USER.md`, la configuración del proveedor de memoria y las claves env del proveedor de memoria mediante HermesHostCompanion."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Spiegelt den Desktop-Memory-Bildschirm: liest und schreibt `memories/MEMORY.md`, `memories/USER.md`, Speicheranbieter-Konfiguration und Speicheranbieter-env-Schlüssel über HermesHostCompanion."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "镜像桌面端 Memory 屏幕：通过 HermesHostCompanion 读取和写入 `memories/MEMORY.md`、`memories/USER.md`、记忆提供商配置和记忆提供商环境变量键。"
          }
        }
      }
    },
    "Mirrors the desktop Providers screen: edits `provider`, `default`, and `base_url` in the live Hermes `config.yaml`, enables streaming, and saves the model to the workspace inventory.": {
      "extractionState": "extracted",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Mirrors the desktop Providers screen: edits `provider`, `default`, and `base_url` in the live Hermes `config.yaml`, enables streaming, and saves the model to the workspace inventory."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Reflète l’écran Providers sur desktop : modifie `provider`, `default` et `base_url` dans le `config.yaml` Hermes actif, active le streaming et enregistre le modèle dans l’inventaire de l’espace de travail."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Refleja la pantalla Providers de escritorio: edita `provider`, `default` y `base_url` en el `config.yaml` activo de Hermes, activa el streaming y guarda el modelo en el inventario del espacio de trabajo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Spiegelt den Desktop-Providers-Bildschirm: bearbeitet `provider`, `default` und `base_url` in der aktiven Hermes-`config.yaml`, aktiviert Streaming und speichert das Modell im Arbeitsbereichsinventar."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "镜像桌面端 Providers 屏幕：编辑实时 Hermes `config.yaml` 中的 `provider`、`default` 和 `base_url`，启用流式输出，并将模型保存到工作区清单。"
          }
        }
      }
    },
